generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  feedbacks Feedback[]
  users     User[]
}

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  createdAt   DateTime   @default(now())
  password    String
  workspaceId Int
  role        Role       @default(VIEWER)
  feedbacks   Feedback[]
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
}

model Feedback {
  id          Int      @id @default(autoincrement())
  message     String
  sentiment   String
  status      String
  theme       String
  channel     String
  createdAt   DateTime @default(now())
  userId      Int?
  workspaceId Int
  confidence  Float?
  summary     String?

  embedding      Json?
  embeddedAt     DateTime?
  embeddingModel String?

  user      User?     @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}
